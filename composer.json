{
    "name": "jasonrouet/feed-favorites",
    "description": "WordPress plugin to synchronize starred items from RSS feeds with WordPress",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Jason Rouet",
            "email": "bonjour@jasonrouet.com",
            "homepage": "https://jasonrouet.local"
        }
    ],
    "keywords": [
        "wordpress",
        "plugin",
        "feedbin",
        "rss",
        "sync",
        "bookmarks",
        "favorites"
    ],
    "homepage": "https://github.com/jaz-on/feed-favorites",
    "support": {
        "issues": "https://github.com/jaz-on/feed-favorites/issues",
        "source": "https://github.com/jaz-on/feed-favorites"
    },
    "require": {
        "php": ">=8.2",
        "composer/installers": "~1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.8",
        "wp-coding-standards/wpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "FeedFavorites\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FeedFavorites\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=WordPress includes/",
        "phpcbf": "phpcbf --standard=WordPress includes/",
        "test:coverage": "phpunit --coverage-html coverage/"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "installer-name": "feed-favorites"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
} 