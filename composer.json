{
    "name": "jaz-on/feed-favorites",
    "description": "Synchronize starred articles from RSS feeds with WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Jason Rouet",
            "email": "bonjour@jasonrouet.com",
            "homepage": "https://jasonrouet.com"
        }
    ],
    "keywords": [
        "wordpress",
        "plugin",
        "rss",
        "sync",
        "bookmarks",
        "favorites",
        "import",
        "content-curation"
    ],
    "homepage": "https://github.com/jaz-on/feed-favorites",
    "support": {
        "issues": "https://github.com/jaz-on/feed-favorites/issues",
        "source": "https://github.com/jaz-on/feed-favorites"
    },
    "require": {
        "php": "^8.2"
    },
    "require-dev": {},
    "autoload": {
        "psr-4": {
            "FeedFavorites\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FeedFavorites\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs --standard=WordPress includes/ --exclude=WordPress.NamingConventions.ValidVariableName,WordPress.DB.SlowDBQuery,WordPress.WP.CronInterval,WordPress.WP.AlternativeFunctions,WordPress.Security.NonceVerification,WordPress.WP.I18n,Squiz.ControlStructures.ControlSignature",
        "phpcbf": "phpcbf --standard=WordPress includes/",
        "test:coverage": "phpunit --coverage-html coverage/"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "installer-name": "feed-favorites"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
} 